public class CharacterInfo {
    private String name;
    private int health;
    private int maxHp;
    private int dmg;
    private boolean isAlive = true;
    
    public String getName(){
        return name;
    }
    
    public void setName(String name){
        this.name = name;
    }
    
    public boolean isAlive(){
        return isAlive;
    }
    
}
